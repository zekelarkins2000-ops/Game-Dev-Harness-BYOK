# Copy this file to .env and fill in your own provider details.
# This harness expects an OpenAI-compatible /chat/completions endpoint.
GDH_API_KEY=sk-your-key-here
GDH_BASE_URL=https://api.openai.com/v1
GDH_MODEL=gpt-5.5

# Optional: use a cheaper model for low-risk helpers.
GDH_FAST_MODEL=gpt-5.5-mini

# Optional engine/tool paths. The doctor command will help detect these.
UNITY_EXE=
UNREAL_ENGINE_ROOT=
DEVKITPRO=
DEVKITARM=
